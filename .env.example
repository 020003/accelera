# Accelera GPU Dashboard - Environment Configuration

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Development server port
VITE_PORT=3000

# Backend API URL
VITE_API_URL=http://localhost:5000

# Backend GPU hosts (comma-separated URLs)
# Configure this to point to your GPU servers running the backend
VITE_BACKEND_HOSTS=http://gpu-host-1:5000,http://gpu-host-2:5000,http://gpu-host-3:5000

# Default refresh interval in milliseconds
VITE_REFRESH_INTERVAL=5000

# Enable demo mode (uses mock data instead of real GPUs)
VITE_ENABLE_DEMO=false

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================

# Flask server configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_ENV=production
FLASK_DEBUG=false

# Security
# Generate with: openssl rand -base64 32
FLASK_SECRET_KEY=your-secure-secret-key-here

# CORS origins (comma-separated)
# Add your frontend domains here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# GPU MONITORING CONFIGURATION
# =============================================================================

# Path to nvidia-smi executable (auto-detected if not set)
NVIDIA_SMI_PATH=/usr/bin/nvidia-smi

# GPU data collection interval in seconds
GPU_COLLECT_INTERVAL=5

# Historical data retention in hours
HISTORICAL_DATA_RETENTION=168

# =============================================================================
# AI INTEGRATION CONFIGURATION
# =============================================================================

# Ollama discovery timeout in milliseconds
OLLAMA_DISCOVER_TIMEOUT=3000

# Default Ollama port
OLLAMA_DEFAULT_PORT=11434

# AI workload timeline retention in hours
AI_TIMELINE_RETENTION=72

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Enable detailed logging
LOG_LEVEL=INFO

# Log file path (optional, logs to stdout if not set)
LOG_FILE_PATH=/var/log/accelera/backend.log

# Enable performance profiling (development only)
ENABLE_PROFILING=false

# Cache timeout for GPU topology data in seconds
TOPOLOGY_CACHE_TIMEOUT=300

# Maximum number of concurrent host connections
MAX_CONCURRENT_HOSTS=10

# =============================================================================
# DATABASE CONFIGURATION (OPTIONAL)
# =============================================================================

# Redis URL for caching and historical data (optional)
# REDIS_URL=redis://localhost:6379/0

# Database URL for persistent storage (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/accelera

# =============================================================================
# MONITORING & OBSERVABILITY (OPTIONAL)
# =============================================================================

# Prometheus metrics endpoint
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090

# Health check endpoint
HEALTH_CHECK_ENABLED=true

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Environment identifier
ENVIRONMENT=production

# Application version (auto-detected from package.json if not set)
# APP_VERSION=2.0.0

# Container timezone
TZ=UTC

# Enable HTTPS redirect (when using reverse proxy)
# FORCE_HTTPS=true

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# API rate limiting (requests per minute)
API_RATE_LIMIT=60

# Enable API authentication (future feature)
# API_AUTH_ENABLED=false
# JWT_SECRET_KEY=your-jwt-secret

# Trusted proxy IPs (comma-separated)
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8

# =============================================================================
# EXAMPLE MULTI-HOST SETUP
# =============================================================================

# For a typical 3-node GPU cluster setup:

# Node 1 (192.168.1.10):
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000

# Node 2 (192.168.1.11):
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000

# Node 3 (192.168.1.12):
# FLASK_HOST=0.0.0.0  
# FLASK_PORT=5000

# Main dashboard:
# VITE_BACKEND_HOSTS=http://192.168.1.10:5000,http://192.168.1.11:5000,http://192.168.1.12:5000

# =============================================================================
# DOCKER COMPOSE OVERRIDES
# =============================================================================

# When using Docker Compose, you can override these variables
# in a docker-compose.override.yml file or .env.local file

# COMPOSE_PROJECT_NAME=accelera
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml