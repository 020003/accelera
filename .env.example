# Accelera — Environment Configuration
# Copy to .env and edit as needed. All values below show their defaults.
#
# Deployment modes:
#   Docker (recommended): set URLs with host.docker.internal
#   Bare-metal:           set URLs with localhost or 127.0.0.1
#   Kubernetes:           set URLs with service DNS names

# ---------------------------------------------------------------------------
# Flask (GPU exporter)
# ---------------------------------------------------------------------------
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Session secret — auto-generated at startup if left empty.
# For production, generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
# FLASK_SECRET_KEY=

# CORS — comma-separated origins, or * to allow all (default).
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# GPU monitoring
# ---------------------------------------------------------------------------
# Path to nvidia-smi (usually auto-detected)
# NVIDIA_SMI_PATH=nvidia-smi

# Collection interval (seconds)
GPU_COLLECT_INTERVAL=60

# How long to keep historical metric data (hours)
HISTORICAL_DATA_RETENTION=168

# ---------------------------------------------------------------------------
# Ollama integration
# ---------------------------------------------------------------------------
# Full URL of the Ollama API server.
# Set explicitly to skip auto-discovery port scanning.
# Leave empty to auto-discover on common ports (11434, 11435, etc.).
# OLLAMA_URL=http://localhost:11434

# If Ollama Prometheus metrics are served by a separate sidecar
# (e.g. ollama-metrics container), set this to its /metrics endpoint.
# Defaults to OLLAMA_URL + /metrics if not set.
# OLLAMA_METRICS_URL=http://localhost:11434/metrics

# Discovery timeout (ms) and default port for auto-discovery
OLLAMA_DISCOVER_TIMEOUT=3000
OLLAMA_DEFAULT_PORT=11434

# ---------------------------------------------------------------------------
# SGLang integration
# ---------------------------------------------------------------------------
# Full URL of the SGLang Runtime server.
# Set explicitly to skip auto-discovery port scanning.
# Leave empty to auto-discover on common ports (30000, 8899, etc.).
# SGLANG_URL=http://localhost:30000

# Discovery timeout (ms) and default port for auto-discovery
SGLANG_DISCOVER_TIMEOUT=3000
SGLANG_DEFAULT_PORT=30000

# ---------------------------------------------------------------------------
# Alerting (optional)
# ---------------------------------------------------------------------------
# Webhook URL called when an alert fires
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# SMTP settings for email alerts
# ALERT_EMAIL_SMTP_HOST=smtp.example.com
# ALERT_EMAIL_SMTP_PORT=587
# ALERT_EMAIL_FROM=alerts@example.com
# ALERT_EMAIL_TO=ops@example.com
# ALERT_EMAIL_PASSWORD=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Directory for SQLite database (created automatically).
# In Docker this is /app/data — mount a volume here for persistence.
# DATA_DIR=server/data

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO